generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String
  password          String
  role              String    @default("USER") // ADMIN, USER
  divisionId        String?
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String    @default("")
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  division          Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  passwordResetTokens PasswordResetToken[]
  emailLogs         EmailLog[]
}

model Division {
  id          String    @id @default(cuid())
  name        String
  description String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projects    Project[]
  users       User[]
}

model Customer {
  id        String    @id @default(cuid())
  name      String
  company   String
  industry  String    @default("")
  email     String    @default("")
  phone     String    @default("")
  address   String    @default("")
  notes     String    @default("")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects  Project[]
}

model Project {
  id                    String    @id @default(cuid())
  name                  String
  customerId            String
  category              String    @default("ONGOING_CUSTOMER") // ONGOING_CUSTOMER, POC_CUSTOMER
  status                String    @default("PLANNING") // PLANNING, IN_PROGRESS, ON_HOLD, COMPLETED, CANCELLED
  description           String    @default("")
  startDate             DateTime?
  endDate               DateTime?
  progress              Int       @default(0)
  budget                Float     @default(0)
  priority              String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  notes                 String    @default("")
  picInternalName       String    @default("")
  picInternalDivisionId String?
  picExternalName       String    @default("")
  pendingType           String    @default("NONE") // NONE, INTERNAL, EXTERNAL
  pendingNote           String    @default("")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  customer              Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  picInternalDivision   Division? @relation(fields: [picInternalDivisionId], references: [id], onDelete: SetNull)
  timelines             Timeline[]
  reports               Report[]
  excelFiles            ExcelFile[]
  activityLogs          ActivityLog[]
}

model Timeline {
  id          String    @id @default(cuid())
  projectId   String
  taskName    String
  startDate   DateTime?
  endDate     DateTime?
  status      String    @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED, DELAYED
  progress    Int       @default(0)
  assignee    String    @default("")
  notes       String    @default("")
  taskOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Report {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  type        String    @default("WEEKLY") // WEEKLY, MONTHLY, MILESTONE, FINAL
  content     String    @default("")
  status      String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ExcelFile {
  id          String    @id @default(cuid())
  projectId   String
  fileName    String
  filePath    String
  uploadedAt  DateTime  @default(now())

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimelineDocument {
  id          String   @id @default(cuid())
  title       String   // Project title e.g. "Deploy Proxmox Private Cloud Timeline Yutaka Manufacturing"
  projectLead String   @default("")
  startDate   String   // ISO date string e.g. "2026-02-01"
  totalWeeks  Int      @default(5)
  phases      String   // JSON string: [{name, tasks: [{description, assignedTo, progress, days}]}]
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User?     @relation(fields: [email], references: [email], onDelete: Cascade)
}

model EmailLog {
  id        String    @id @default(cuid())
  to        String
  subject   String
  body      String
  status    String    @default("SENT") // SENT, FAILED
  createdAt DateTime  @default(now())

  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  projectId  String
  userId     String
  userName   String
  action     String   // CREATE, UPDATE, DELETE, VIEW
  entity     String   // project, timeline, report, excel
  entityName String   // name of the entity (e.g. task name, report title)
  details    String   @default("")
  createdAt  DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}